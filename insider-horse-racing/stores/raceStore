import {defineStore} from "pinia";

const horseColors = [
    {name: "Red", value: "#FB2C36"},
    {name: "Burgundy", value: "#660033"},
    {name: "Orange", value: "#FF692A"},
    {name: "Yellow", value: "#FFDF20"},
    {name: "Lime", value: "#BBF451"},
    {name: "Green", value: "#2AA63E"},
    {name: "Cyan", value: "#46ECD5"},
    {name: "Blue", value: "#155DFC"},
    {name: "Purple", value: "#7008E7"},
    {name: "Magenta", value: "#FD3DB5"},
    {name: "Pink", value: "#f28fff"},
    {name: "Brown", value: "#7E2A0C"},
    {name: "White", value: "#e9f4ff"},
    {name: "Gray", value: "#90A1B9"},
]


function generateHorse(i){
    return{
        id: i,
        condition: Math.floor(Math.random() * 100) + 1,
        color: horseColors[Math.floor(Math.random() * horseColors.length)]
    }
}

function simulateHorseRace(horse, distance){
    const tileSize = 200
    const totalTiles = distance / tileSize
    const edgetiles = 4
    const middleTiles = totalTiles - edgetiles
    const edgeSpeed = horse.condition * 0.5 + Math.random() * 200 + 30
    const edgeTime = tileSize / edgeSpeed
    const middleSpeed = 1.5 * (horse.condition) + (Math.random() * 75) + 30
    const middleTime = tileSize / middleSpeed
    const finishTime = edgetiles * edgeTime + middleTiles * middleTime

    return{
        ...horse,
        finishTime,
        edgeSpeed,
        edgeTime,
        middleTime,
    }
}

function simulateRace(racingHorses, distance, raceId){
    let raceResult = []
    for(let i = 0; i < racingHorses.length; i++){
        raceResult.push(simulateHorseRace(racingHorses[i], distance))
    }
    raceResult.sort((a, b) => a.finishTime - b.finishTime)

    return{
        raceId,
        distance,
        raceResult, 
    }
}

function buildRaceTiles(distance){
    const totalTiles = distance / 200 //every race is a multiple of 200
    return Array.from({length: totalTiles}, (_, index) => {
        //start and finish tiles are for visuals only they work as edge tiles in the race
        if(index === 0){
            return{
                id: index,
                type: "start",
            }
        }
        if(index === totalTiles - 1){
            return{
                id: index,
                type: "finish",
            }
        }
        if(index === 1 || index === totalTiles - 2){
            return{
                id: index,
                type: "edge",
            }
        }
        return{
            id: index,
            type: "middle",
        }
    })
}

function wait(seconds){
    let timeoutId
    let resolvePromise
    const promise = new Promise((resolve) => {
        resolvePromise = resolve
        timeoutId = setTimeout(resolve, seconds * 1000)
    })

    return {
        promise,
        cancel() { //used to skip the races
        clearTimeout(timeoutId)
        resolvePromise()
        },
    }
}



export const useRaceStore = defineStore(
    "race",
    {
        state: () => ({
            horses: [],
            racingHorses: [],
            distances: [1200, 1400, 1600, 1800, 2000, 2200],
            currentRace: 0,
            raceResults: [],
            raceTiles: [],
            currentRaceResult: null,
            raceStatus: "idle",
            horsePositions: {},
            activeWaits: [],
            isSkippingRace: false,
        }),

        actions: {
            generateHorses() {
                this.horses = [] //Clear the existing horses
                this.racingHorses = []
                for(let i = 0; i < 20; i++){
                    this.horses.push(generateHorse(i))
                }
            },

            chooseHorses(){
                const shuffledHorses = [...this.horses].sort(() => Math.random() - 0.5) //shuffle the horses
                this.racingHorses = shuffledHorses.slice(0, 10) //take the first 10
            },

            async animateHorse(horse){
                this.horsePositions[horse.id] = 0

                for (let i = 0; i < this.raceTiles.length; i++) {
                    if (this.isSkippingRace) {
                    this.horsePositions[horse.id] = this.raceTiles.length
                    return
                    }

                    const tile = this.raceTiles[i]
                    const tileTime = tile.type === "middle" ? horse.middleTime : horse.edgeTime
                    const activeWait = wait(tileTime)
                    this.activeWaits.push(activeWait)
                    await activeWait.promise
                    this.activeWaits = this.activeWaits.filter((item) => item !== activeWait)
                    if (this.isSkippingRace) {
                    this.horsePositions[horse.id] = this.raceTiles.length
                    return
                    }
                    this.horsePositions[horse.id] = i + 1
                }
            },

            skipRace(){
                this.isSkippingRace = true
                for (const horse of this.racingHorses) {
                    this.horsePositions[horse.id] = this.raceTiles.length
                }
                for (const activeWait of this.activeWaits) {
                    activeWait.cancel()
                }
                this.activeWaits = []
            },

            startTournament(){
                this.generateHorses()
                this.currentRace = 0
                this.raceResults = []
                this.prepareCurrentRace()
            },

            prepareCurrentRace(){
                this.isSkippingRace = false
                this.activeWaits = []
                this.chooseHorses()
                this.generateRace()
                this.horsePositions = {}
                this.currentRaceResult = null
                this.raceStatus = "ready"

            },

            async runCurrentRace(){
                const distance = this.distances[this.currentRace]
                const result = simulateRace(this.racingHorses, distance, this.currentRace + 1)
                this.currentRaceResult = result
                this.raceStatus = "running"
                this.horsePositions = {}
                await Promise.all(result.raceResult.map((horse) => this.animateHorse(horse)))
                this.raceResults.push(result)
                if(this.currentRace >= this.distances.length - 1){
                    this.raceStatus = "tournamentFinished"
                }else{
                    this.raceStatus = "finished"
                }
            },

            nextRace(){
                if(this.currentRace >= this.distances.length - 1){
                    return
                }

                this.currentRace++
                this.prepareCurrentRace()

            },

            simulateRaces(){
                this.raceResults = [] //Clear existing race results
                for(let i = 0; i < this.distances.length; i++){
                    const idRaceResult = simulateRace(this.racingHorses, this.distances[i], i + 1)
                    this.raceResults.push(idRaceResult)
                }
            },

            generateRace() {
                const curDistance = this.distances[this.currentRace]
                this.raceTiles = buildRaceTiles(curDistance)
            }

        }
    }
)